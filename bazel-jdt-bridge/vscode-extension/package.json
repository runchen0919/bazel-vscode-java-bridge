{
    "name": "bazel-jdt-bridge",
    "displayName": "Bazel Java Support",
    "description": "Bazel Java dependency resolver for Eclipse JDT.LS",
    "version": "0.1.0",
    "publisher": "bazel-jdt",
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "Programming Languages",
        "Other"
    ],
    "activationEvents": [
        "onLanguage:java",
        "workspaceContains:WORKSPACE",
        "workspaceContains:WORKSPACE.bazel"
    ],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "bazel-jdt.importProject",
                "title": "Bazel: Import Project"
            },
            {
                "command": "bazel-jdt.syncProject",
                "title": "Bazel: Sync Project"
            },
            {
                "command": "bazel-jdt.cleanCache",
                "title": "Bazel: Clean Cache"
            }
        ],
        "configuration": {
            "title": "Bazel JDT Bridge",
            "properties": {
                "bazel-jdt.bazelPath": {
                    "type": "string",
                    "default": "bazel",
                    "description": "Path to Bazel binary"
                },
                "bazel-jdt.syncOnSave": {
                    "type": "boolean",
                    "default": true,
                    "description": "Auto-sync when BUILD files are saved"
                },
                "bazel-jdt.cacheDir": {
                    "type": "string",
                    "default": "",
                    "description": "Cache directory"
                }
            }
        },
        "javaExtensions": [
            "./server/com.bazel.jdt.jar"
        ]
    },
    "extensionDependencies": [
        "redhat.java"
    ],
    "devDependencies": {
        "@types/mocha": "^10.0.9",
        "@types/node": "^18.19.130",
        "@types/vscode": "^1.85.0",
        "@vscode/test-electron": "^2.4.0",
        "esbuild": "^0.20.0",
        "glob": "^8.1.0",
        "mocha": "^10.8.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.0"
    },
    "scripts": {
        "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap",
        "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --target=node18 --sourcemap --watch",
        "build-tests": "node scripts/build-tests.mjs",
        "e2e": "npm run build-tests && NODE_PATH=./node_modules node ../tests/e2e/out/runTests.js",
        "e2e:full": "npm run e2e && TEST_WORKSPACE=maven-deps-project npm run e2e && TEST_WORKSPACE=multi-module-project npm run e2e"
    }
}
